pipeline {

    agent any

    tools {
        jdk 'JDK11'
        maven 'Maven3'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git 'https://github.com/yourusername/yourrepo.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'mvn test'
            }
        }

    }

    post {

        always {
            junit '**/target/surefire-reports/*.xml'
        }

        success {
            echo 'Tests executed successfully!'
        }

        failure {
            echo 'Build Failed!'
        }
    }
}